---
import '../assets/item.css'
import 'prismjs/themes/prism.css'
import dayjs from '../lib/dayjs'
import { getEnv } from '../lib/env'

const locale = getEnv(import.meta.env, Astro, 'LOCALE')
const timezone = getEnv(import.meta.env, Astro, 'TIMEZONE')
const channel = getEnv(import.meta.env, Astro, 'CHANNEL')

locale && dayjs.locale(locale)

const { SITE_URL } = Astro.locals
const { post } = Astro.props

const datetime = dayjs(post.datetime).tz(timezone)
const timeago = datetime.isBefore(dayjs().subtract(1, 'w'))
  ? datetime.format('HH:mm · ll · ddd')
  : datetime.fromNow()
---

<div class="item" style={{ 'view-transition-name': `post-${post.id}` }}>
  <div class="item-header">
    <div class="time-box">
      <div class="dot"></div>
      <div class="time">
        <a
          href={`${SITE_URL}posts/${post.id}`}
          title={post.datetime}
          class="item-link">{timeago}</a
        >
      </div>
    </div>
    <button
      class="save-button"
      data-post-id={post.id}
      data-channel={channel}
      onclick="handleSave(this)"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
      </svg>
    </button>
  </div>
  {
    post.content.length > 0 && (
      <div class={`text-box content`} set:html={post.content} />
    )
  }
  {
    post.tags.length > 0 && (
      <div
        class="tag-box"
        style={post.content.length === 0 ? 'padding-top: 30px;' : ''}
      >
        <div class="tag-icon" />
        {post.tags.map((tag) => (
          <a href={`/search/%23${tag}`} title={tag} class="tag">
            {tag}
          </a>
        ))}
      </div>
    )
  }
</div>

<script define:vars={{ channel }}>
  const CHANNEL_NAME = channel

  async function handleSave(button) {
    const postId = button.getAttribute('data-post-id')
    const channelName = button.getAttribute('data-channel') || CHANNEL_NAME
    const buttonText = button.querySelector('svg')

    console.log('[Save] Starting save process', { postId, channelName, CHANNEL_NAME })

    if (!postId || !channelName) {
      console.error('[Save] Missing post ID or channel name', { postId, channelName, CHANNEL_NAME })
      alert('保存失败: 缺少帖子 ID 或频道名称')
      return
    }

    button.disabled = true
    buttonText.innerHTML = '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />'

    try {
      console.log('[Save] Sending API request', { postId, channel: channelName })

      const response = await fetch('/api/save', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ postId, channel: channelName }),
      })

      console.log('[Save] Response received', { status: response.status, ok: response.ok })

      const data = await response.json()
      console.log('[Save] Response data', data)

      if (!response.ok) {
        throw new Error(data.error || `HTTP error! status: ${response.status}`)
      }

      if (data.success) {
        buttonText.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>'
        button.classList.add('saved')
        console.log('[Save] Successfully saved')

        setTimeout(() => {
          button.disabled = false
          buttonText.innerHTML = '<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>'
          button.classList.remove('saved')
          console.log('[Save] Button reset')
        }, 2000)
      }
      else {
        throw new Error(data.error || 'Failed to save')
      }
    }
    catch (error) {
      console.error('[Save] Error:', error)
      buttonText.innerHTML = '<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>'
      button.disabled = false

      alert(`保存失败: ${error.message}`)
    }
  }

  // 在页面加载时输出调试信息
  console.log('[Save Debug] Channel name:', CHANNEL_NAME)
  console.log('[Save Debug] Save buttons found:', document.querySelectorAll('.save-button').length)

  document.querySelectorAll('.save-button').forEach((btn, index) => {
    console.log(`[Save Debug] Button ${index}:`, {
      postId: btn.getAttribute('data-post-id'),
      channel: btn.getAttribute('data-channel'),
    })
  })
</script>





